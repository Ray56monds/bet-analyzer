# ── Sports data (football + basketball + tennis — same key) ──
# Get free key: https://dashboard.api-football.com/register
API_FOOTBALL_KEY=your_api_key_here

# ── Real bookmaker odds ───────────────────────────────────────
# Get free key (500 req/month): https://the-odds-api.com/#get-access
ODDS_API_KEY=your_odds_key_here

# ── Email alerts ──────────────────────────────────────────────
# Use a Gmail App Password (not your main password):
# Google Account → Security → 2-Step Verification → App Passwords
NOTIFY_FROM=your_gmail@gmail.com
NOTIFY_PASSWORD=your_16char_app_password
NOTIFY_TO=recipient1@email.com,recipient2@email.com

# ── Flask ─────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_PORT=5000
